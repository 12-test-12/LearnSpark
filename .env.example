# =============================================================================
# LearnSpark 环境变量示例
#
# 使用方法：复制为 .env 并按需修改
#   cp .env.example .env
# =============================================================================

# ---- MySQL ----
DB_USER=root
DB_PASSWORD=root

# ---- MinIO ----
APP_MINIO_ENDPOINT=http://minio:9000
APP_MINIO_ACCESS_KEY=minioadmin
APP_MINIO_SECRET_KEY=minioadmin
APP_MINIO_BUCKET=learnspark

# ---- 应用密钥（生产环境务必修改）----
APP_JWT_SECRET=learnspark-production-jwt-secret-please-change-at-least-32-chars
APP_AES_SECRET=learnspark-production-aes-key-32bytes-change

# ---- CORS ----
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- 邮件 SMTP（提醒功能）----
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM=learnspark@noreply.com

# ---- 后端服务（供 frontend 容器访问）----
BACKEND_HOST=backend
BACKEND_PORT=8080
