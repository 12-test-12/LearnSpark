# 阶段 3.2：环境变量模板
# 复制为 .env 后填入实际值（生产环境请用 secrets manager）

# MySQL
MYSQL_ROOT_PASSWORD=ChangeMe_RootPass_2026
MYSQL_DATABASE=learnspark
MYSQL_USER=learnspark
MYSQL_PASSWORD=ChangeMe_LearnPass_2026
MYSQL_PORT=3306

# API 服务端口（宿主机）
API_PORT=8080

# HTTPS（生产环境）
HTTPS_PORT=443
HTTP_PORT=80

# JWT 签名密钥（必须 ≥ 256 bit，对应 HS256）
# 生成：openssl rand -base64 48
JWT_SECRET=ChangeMe_To_Random_48_Bytes_Base64_2026_Secret_Key_Here

# 文件上传
LEARNSPARK_UPLOAD_DIR=/var/learnspark/uploads
